{
  "name": "smartlic-frontend",
  "version": "0.1.0",
  "private": true,
  "description": "Frontend for SmartLic — Inteligência em Licitações",
  "scripts": {
    "dev": "next dev",
    "build": "next build --webpack && npm run postbuild",
    "postbuild": "cp -r public .next/standalone/ && cp -r .next/static .next/standalone/.next/",
    "postbuild:sitemap": "next-sitemap",
    "start": "node .next/standalone/server.js",
    "lint": "next lint",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:ci": "jest --ci --coverage --maxWorkers=2",
    "test:quarantine": "jest --testPathPattern='__tests__/quarantine/' --testPathIgnorePatterns='/node_modules/' --no-coverage --passWithNoTests",
    "test:e2e": "playwright test",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:debug": "playwright test --debug",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:report": "playwright show-report",
    "generate:api-types": "bash ../scripts/generate-api-types.sh",
    "generate:api-types:check": "bash ../scripts/generate-api-types.sh --check",
    "lighthouse": "lhci autorun",
    "lighthouse:collect": "lhci collect",
    "lighthouse:assert": "lhci assert",
    "size-limit": "size-limit",
    "analyze": "ANALYZE=true next build --webpack"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@hookform/resolvers": "^5.2.2",
    "@radix-ui/react-slot": "^1.2.4",
    "@sentry/nextjs": "^10.49.0",
    "@stripe/react-stripe-js": "^6.2.0",
    "@stripe/stripe-js": "^9.2.0",
    "@supabase/ssr": "^0.8.0",
    "@supabase/supabase-js": "^2.99.3",
    "@tailwindcss/typography": "^0.5.19",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "focus-trap-react": "^12.0.0",
    "framer-motion": "^12.38.0",
    "lucide-react": "^0.563.0",
    "mixpanel-browser": "^2.74.0",
    "next": "^16.1.6",
    "nprogress": "^0.2.0",
    "react": "^18.3.1",
    "react-day-picker": "^9.14.0",
    "react-dom": "^18.3.1",
    "react-hook-form": "^7.73.1",
    "react-markdown": "^10.1.0",
    "react-simple-pull-to-refresh": "^1.3.4",
    "recharts": "^3.7.0",
    "remark-gfm": "^4.0.1",
    "sonner": "^2.0.7",
    "swr": "^2.4.1",
    "tailwind-merge": "^3.5.0",
    "use-debounce": "^10.1.0",
    "uuid": "^13.0.0",
    "web-vitals": "^5.2.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.1",
    "@chromatic-com/playwright": "^0.13.1",
    "@lhci/cli": "^0.15.0",
    "@next/bundle-analyzer": "^16.2.4",
    "@playwright/test": "^1.58.2",
    "@size-limit/file": "^11.2.0",
    "@storybook/addon-essentials": "^8.6.14",
    "@storybook/blocks": "^8.6.14",
    "@storybook/nextjs": "^8.6.18",
    "@storybook/react": "^8.6.18",
    "@storybook/react-webpack5": "^8.6.18",
    "@storybook/test": "^8.6.18",
    "@swc/core": "^1.15.26",
    "@swc/jest": "^0.2.29",
    "@testing-library/jest-dom": "^6.1.5",
    "@testing-library/react": "^14.1.2",
    "@testing-library/user-event": "^14.5.1",
    "@types/jest-axe": "^3.5.9",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^25.2.0",
    "@types/nprogress": "^0.2.3",
    "@types/react": "^19.2.9",
    "@types/react-dom": "^19.2.3",
    "@types/uuid": "^10.0.0",
    "autoprefixer": "^10.4.24",
    "eslint-plugin-local-rules": "^3.0.2",
    "jest": "^29.7.0",
    "jest-axe": "^10.0.0",
    "jest-environment-jsdom": "^29.7.0",
    "jest-junit": "^16.0.0",
    "js-yaml": "^4.1.1",
    "next-sitemap": "^4.2.3",
    "openapi-typescript": "^7.13.0",
    "postcss": "^8.5.12",
    "size-limit": "^11.2.0",
    "storybook": "^8.6.18",
    "tailwindcss": "^3.4.19",
    "typescript": "^5.9.3"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  }
}
